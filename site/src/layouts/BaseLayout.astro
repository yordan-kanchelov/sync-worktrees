---
import "../styles/globals.css";
import packageMetadata from "../../../package.json";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = "sync-worktrees — Keep every branch checked out. For you and your AI agents.",
  description = "Materialize your entire Git branch + repo layout on disk and expose it to any MCP-compatible AI tool. No stashing, no re-cloning, no re-explaining your codebase to Claude Code, Cursor, Codex, or Windsurf.",
  canonical,
  ogImage = "/og-image.png",
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://sync-worktrees.dev";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const packageVersion = packageMetadata.version;

const faqEntries = [
  {
    q: "What's the difference between git worktree and sync-worktrees?",
    a: "git worktree is the underlying Git primitive: a single command that adds one extra working directory tied to a bare repository. sync-worktrees is a workspace orchestrator built on top of it — it manages the bare repo, materializes a directory for every remote branch automatically, prunes them when branches are deleted upstream, and keeps the whole thing fresh on a cron schedule. It also ships an interactive TUI and an MCP server so AI agents can navigate and operate the workspace.",
  },
  {
    q: "Why use this instead of cloning each branch separately?",
    a: "Cloning duplicates the entire Git object database for every branch — wasteful on disk and slow to refresh. Worktrees share one .git directory among many checkouts, so disk usage scales with working-tree size, not with branch count. sync-worktrees automates the bookkeeping you'd otherwise have to do manually (creating worktrees for new remote branches, removing stale ones, handling force-pushes safely).",
  },
  {
    q: "How does the MCP server help AI coding agents?",
    a: "The bundled sync-worktrees-mcp binary speaks the Model Context Protocol over stdio. AI agents (Claude Code, Cursor, Windsurf, Codex, Cline, opencode, Warp, Gemini CLI, VS Code Copilot) can call detect_context, list_worktrees, create_worktree, sync, and update_worktree directly. In a single detect_context call with includeAllWorktrees: true, an agent working in one repo discovers every sibling repo and worktree you have configured — so 'go look in the other repo' actually works without manual re-orientation.",
  },
  {
    q: "Does it work with monorepos?",
    a: "Yes. Per-repo branch include/exclude globs and sparse-checkout support let you scope each worktree to the slice of the monorepo you actually care about. Combined with branchMaxAge to ignore stale branches, this keeps multi-million-line monorepos manageable on disk.",
  },
  {
    q: "What happens when a branch is force-pushed or deleted upstream?",
    a: "Force-pushes are detected and the divergent working copy is moved aside into a .diverged/ directory rather than overwritten — uncommitted work is never silently lost. Deleted branches have their worktrees removed only if they are clean, with no unpushed commits, no stashes, and no operation in progress; anything else is preserved and surfaced in the TUI's status view.",
  },
  {
    q: "Can I run it continuously or on a cron?",
    a: "Yes. The default invocation launches the interactive TUI and syncs continuously based on the cronSchedule field in your config (per-repo overrides are supported). For one-shot or scripted use, pass --runOnce. For CI pipelines, point --config at your workspace config and the same one-shot path applies.",
  },
  {
    q: "Is it safe with uncommitted work?",
    a: "Yes. Sync operations never merge or rebase your working copies. They fetch, create missing worktrees, fast-forward eligible existing worktrees, and prune only when the safety checks pass. Worktree removal refuses on dirty trees, unpushed commits, stashes, or in-progress operations (merge/rebase/cherry-pick/revert/bisect). Newly created branches are pushed with explicit --no-track so they don't inherit origin/main as upstream by accident.",
  },
];

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "sync-worktrees",
  description,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux",
  url: siteUrl,
  downloadUrl: "https://www.npmjs.com/package/sync-worktrees",
  softwareVersion: packageVersion,
  license: "https://opensource.org/licenses/MIT",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  author: {
    "@type": "Person",
    name: "Yordan Kanchelov",
    url: "https://github.com/yordan-kanchelov",
  },
  codeRepository: "https://github.com/yordan-kanchelov/sync-worktrees",
  programmingLanguage: "TypeScript",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqEntries.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="theme-color" content="#0e1119" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="sync-worktrees" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Hints for crawlers and AI tools -->
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM entry point" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="Full text for LLM training" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </head>
  <body class="bg-white text-ink-900 font-sans antialiased">
    <slot />

    <script>
      // copy-to-clipboard for any [data-copy] button
      document.addEventListener("click", (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const btn = target.closest("[data-copy]");
        if (!btn) return;
        const text = btn.getAttribute("data-copy") ?? "";
        navigator.clipboard.writeText(text).then(() => {
          btn.classList.add("copied");
          setTimeout(() => btn.classList.remove("copied"), 1600);
        });
      });

      // simple tab switcher for [data-tabs]
      document.querySelectorAll("[data-tabs]").forEach((root) => {
        const buttons = root.querySelectorAll("[role='tab']");
        const panels = root.querySelectorAll("[role='tabpanel']");
        buttons.forEach((btn) => {
          btn.addEventListener("click", () => {
            const id = btn.getAttribute("data-tab");
            buttons.forEach((b) => {
              const selected = b.getAttribute("data-tab") === id;
              b.setAttribute("aria-selected", String(selected));
              b.setAttribute("tabindex", selected ? "0" : "-1");
            });
            panels.forEach((p) => {
              const matches = p.getAttribute("data-panel") === id;
              if (matches) p.removeAttribute("hidden");
              else p.setAttribute("hidden", "");
            });
          });
        });
      });
    </script>
  </body>
</html>
