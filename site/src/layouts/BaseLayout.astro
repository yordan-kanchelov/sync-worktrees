---
import "../styles/globals.css";
import packageMetadata from "../../../package.json";
import PostHogAnalytics from "../components/PostHogAnalytics.astro";
import { getCollection, getEntry } from "astro:content";
import { mdToPlainText } from "../lib/markdown-inline";

const positioning = (await getEntry("positioning", "main"))!.data;

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = positioning.metaTitle,
  description = positioning.metaDescription,
  canonical,
  ogImage = "/og-image.png",
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://sync-worktrees.com";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const packageVersion = packageMetadata.version;

const faqs = (await getCollection("faq")).sort((a, b) => a.data.order - b.data.order);

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "sync-worktrees",
  description,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux",
  url: siteUrl,
  downloadUrl: "https://www.npmjs.com/package/sync-worktrees",
  softwareVersion: packageVersion,
  license: "https://opensource.org/licenses/MIT",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  author: {
    "@type": "Person",
    name: "Yordan Kanchelov",
    url: "https://github.com/yordan-kanchelov",
  },
  codeRepository: "https://github.com/yordan-kanchelov/sync-worktrees",
  programmingLanguage: "TypeScript",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((entry) => ({
    "@type": "Question",
    name: entry.data.question,
    acceptedAnswer: { "@type": "Answer", text: mdToPlainText(entry.body ?? "") },
  })),
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="theme-color" content="#0e1119" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={positioning.ogImageAlt} />
    <meta property="og:site_name" content="sync-worktrees" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={positioning.ogImageAlt} />

    <!-- Hints for crawlers and AI tools -->
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM entry point" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="Full text for LLM training" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <PostHogAnalytics />
  </head>
  <body class="bg-white text-ink-900 font-sans antialiased">
    <slot />

    <script>
      // copy-to-clipboard for any [data-copy] button
      document.addEventListener("click", (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const btn = target.closest("[data-copy]");
        if (!btn) return;
        const text = btn.getAttribute("data-copy") ?? "";
        navigator.clipboard.writeText(text).then(() => {
          btn.classList.add("copied");
          setTimeout(() => btn.classList.remove("copied"), 1600);
          (window as any).posthog?.capture("command_copied", { command: text });
        });
      });

      // simple tab switcher for [data-tabs]
      document.querySelectorAll("[data-tabs]").forEach((root) => {
        const buttons = root.querySelectorAll("[role='tab']");
        const panels = root.querySelectorAll("[role='tabpanel']");
        buttons.forEach((btn) => {
          btn.addEventListener("click", () => {
            const id = btn.getAttribute("data-tab");
            (window as any).posthog?.capture("agent_tab_selected", { agent: id });
            buttons.forEach((b) => {
              const selected = b.getAttribute("data-tab") === id;
              b.setAttribute("aria-selected", String(selected));
              b.setAttribute("tabindex", selected ? "0" : "-1");
            });
            panels.forEach((p) => {
              const matches = p.getAttribute("data-panel") === id;
              if (matches) p.removeAttribute("hidden");
              else p.setAttribute("hidden", "");
            });
          });
        });
      });
    </script>
  </body>
</html>
