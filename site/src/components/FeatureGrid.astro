---
import Icon from "./Icon.astro";

const features = [
  {
    icon: "git-branch",
    title: "Worktree mode",
    body: "Every remote branch gets its own directory, all sharing one .git database. Disk usage scales with working-tree size, not branch count.",
  },
  {
    icon: "clone",
    title: "Clone mode",
    body: "When one checkout is enough, drop a plain single-branch clone at a fixed path. First-class alternative for dependency siblings.",
  },
  {
    icon: "robot",
    title: "MCP server",
    body: "Ships sync-worktrees-mcp as a second binary. AI agents call detect_context, list, create, sync, update — directly, over stdio.",
  },
  {
    icon: "monitor",
    title: "Interactive TUI",
    body: "Ink-based terminal UI with wizards for opening worktrees in editor or terminal, creating branches, and inspecting multi-repo status.",
  },
  {
    icon: "filter",
    title: "Smart filtering",
    body: "Glob include/exclude, age-based pruning, sparse checkout for monorepos, per-repo overrides. Keep huge repos manageable.",
  },
  {
    icon: "shield",
    title: "Safety by default",
    body: "Force-push detection with .diverged/ preservation. Refuses to remove worktrees with uncommitted work, unpushed commits, or stashes.",
  },
];
---
<section class="bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-ink-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-ink-600">
        Features
      </div>
      <h2 class="mt-4 text-balance text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        A workspace orchestrator, not a wrapper.
      </h2>
      <p class="mt-4 text-balance text-lg text-ink-600">
        Built on top of <code class="font-mono text-base">git worktree</code>, sync-worktrees handles the bookkeeping you'd otherwise do by hand — and exposes it to humans and AI agents through the same surface.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map(({ icon, title, body }) => (
        <div class="group relative rounded-2xl border border-ink-200 bg-white p-6 transition hover:border-accent-300 hover:shadow-md">
          <div class="inline-flex size-10 items-center justify-center rounded-lg bg-accent-50 text-accent-700 ring-1 ring-accent-100 transition group-hover:bg-accent-100">
            <Icon name={icon as any} size={20} />
          </div>
          <h3 class="mt-4 text-base font-semibold text-ink-900">{title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-600">{body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
