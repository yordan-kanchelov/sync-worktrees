---
import { getCollection, getEntry } from "astro:content";
import Icon from "./Icon.astro";
import CopyButton from "./CopyButton.astro";
import { Code } from "astro:components";

const commands = (await getEntry("commands", "main"))!.data;

const tabs = (await getCollection("clients"))
  .sort((a, b) => a.data.order - b.data.order)
  .map((c) => ({
    id: c.id,
    label: c.data.label,
    lang: c.data.lang,
    hint: c.data.hint,
    code: c.data.useStandardJson ? commands.standardJson : (c.data.code ?? commands.claudeMcpAdd),
  }));

const mcpTools = (await getCollection("mcpTools"))
  .sort((a, b) => a.data.order - b.data.order)
  .map((t) => [t.data.name, t.data.desc] as const);
---
<section id="agents" class="relative overflow-hidden bg-ink-950 py-20 sm:py-28 text-ink-100">
  <div class="absolute inset-0 -z-0 section-grid-dark"></div>
  <div class="absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-accent-500/40 to-transparent"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-ink-700 bg-ink-900/60 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-accent-300">
        <Icon name="sparkle" size={12} /> AI agents
      </div>
      <h2 class="mt-4 text-balance text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Your workspace, exposed over MCP.
      </h2>
      <p class="mt-4 text-balance text-lg text-ink-300">
        Installing the npm package ships a second binary, <code class="font-mono text-base text-accent-300">sync-worktrees-mcp</code>, that speaks the Model Context Protocol over stdio. Wire it into any MCP client and your agent can list, create, inspect, and sync worktrees directly.
      </p>
    </div>

    <div class="mt-12 rounded-2xl border border-ink-700 bg-ink-900/70 p-1.5 shadow-2xl" data-tabs>
      <div role="tablist" aria-label="MCP setup per AI tool" class="flex flex-wrap gap-1 rounded-xl bg-ink-950/60 p-1">
        {tabs.map((t, i) => (
          <button
            type="button"
            role="tab"
            data-tab={t.id}
            aria-selected={i === 0 ? "true" : "false"}
            tabindex={i === 0 ? 0 : -1}
            class="tab-button rounded-lg px-3 py-1.5 text-sm font-medium text-ink-300 transition hover:text-white"
          >
            {t.label}
          </button>
        ))}
      </div>

      {tabs.map((t, i) => (
        <div
          role="tabpanel"
          data-panel={t.id}
          hidden={i === 0 ? undefined : true}
          class="tab-panel p-4 sm:p-5"
        >
          <div class="flex items-center justify-between gap-3">
            <p class="text-sm text-ink-400">{t.hint}</p>
            <CopyButton value={t.code} class="bg-ink-800 text-ink-200 hover:bg-ink-700" />
          </div>
          <div class="mt-3 overflow-x-auto rounded-xl border border-ink-800 bg-ink-950/80">
            <Code code={t.code} lang={t.lang as any} theme="github-dark-default" wrap />
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-[1fr_1.2fr]">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-ink-700 bg-ink-900/60 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-ink-300">
          What your agent can do
        </div>
        <h3 class="mt-4 text-2xl font-bold text-white sm:text-3xl">
          One <code class="font-mono text-xl text-accent-300">detect_context</code> call. The configured workspace shape.
        </h3>
        <p class="mt-4 text-ink-300">
          An agent working in <code class="font-mono text-sm text-accent-300">frontend/</code> can call <code class="font-mono text-sm text-accent-300">detect_context</code> with <code class="font-mono text-sm text-accent-300">includeAllWorktrees: true</code> to discover every sibling repo and worktree you have configured — so "go look in the other repo" actually works without you re-orienting it.
        </p>
        <p class="mt-3 text-sm text-ink-400">
          The response includes a per-capability <code class="font-mono text-xs text-accent-300">{`{ available, reason }`}</code> block, so the agent knows up front whether <code class="font-mono text-xs text-accent-300">sync</code>, <code class="font-mono text-xs text-accent-300">initialize</code>, or per-worktree operations will work from its current vantage point.
        </p>
      </div>

      <div class="rounded-2xl border border-ink-800 bg-ink-900/40 p-5">
        <ul class="divide-y divide-ink-800">
          {mcpTools.map(([name, desc]) => (
            <li class="flex flex-col gap-1 py-3 first:pt-0 last:pb-0 sm:flex-row sm:gap-4">
              <code class="shrink-0 font-mono text-sm font-semibold text-accent-300 sm:w-44">{name}</code>
              <span class="text-sm text-ink-300">{desc}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
