---
import { getEntry } from "astro:content";
import Icon from "./Icon.astro";
import CopyButton from "./CopyButton.astro";
import packageMetadata from "../../../package.json";
import { inlineCodeToHtml } from "../lib/markdown-inline";

const commands = (await getEntry("commands", "main"))!.data;
const positioning = (await getEntry("positioning", "main"))!.data;
const npmCmd = commands.npmInstall;
const packageVersion = packageMetadata.version;

const showcaseConfig = `repositories: [
  {
    name: "frontend",
    repoUrl: "github.com/acme/frontend",
  },
  {
    name: "backend",
    repoUrl: "github.com/acme/backend",
  },
];`;

// Live star count, fetched at build time. Falls back to no count if the API is
// unreachable or rate-limited so the build never depends on network access.
let starCount: number | null = null;
try {
  const res = await fetch("https://api.github.com/repos/yordan-kanchelov/sync-worktrees", {
    signal: AbortSignal.timeout(3000),
    headers: { Accept: "application/vnd.github+json", "User-Agent": "sync-worktrees-site" },
  });
  if (res.ok) {
    const data = await res.json();
    if (typeof data.stargazers_count === "number") starCount = data.stargazers_count;
  }
} catch {
  starCount = null;
}
const starLabel =
  starCount === null ? null : starCount >= 1000 ? `${(starCount / 1000).toFixed(1)}k` : `${starCount}`;
---
<section class="relative overflow-hidden bg-white">
  <div class="absolute inset-0 -z-10 section-grid-light"></div>
  <div class="absolute inset-x-0 top-0 -z-10 h-96 bg-gradient-to-b from-accent-50/60 via-transparent to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 pt-20 pb-12 sm:pt-28 sm:pb-16">
    <div class="flex justify-center">
      <a
        href="https://github.com/yordan-kanchelov/sync-worktrees"
        class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white/70 px-3 py-1 text-xs font-medium text-ink-700 backdrop-blur transition hover:border-accent-300 hover:text-accent-700"
      >
        <span class="inline-block size-1.5 rounded-full bg-signal-green"></span>
        v{packageVersion} — MIT licensed
        <span class="text-ink-400">·</span>
        <span class="inline-flex items-center gap-1">
          <Icon name="github" size={14} /> Star on GitHub
        </span>
        <span
          id="gh-stars"
          class:list={[
            "ml-0.5 inline-flex items-center gap-1 rounded-full bg-ink-100 px-1.5 py-0.5 text-[11px] font-semibold text-ink-700",
            { hidden: !starLabel },
          ]}
        >
          ★ <span data-star-value>{starLabel}</span>
        </span>
      </a>
    </div>

    <p class="mt-8 text-center text-xs font-semibold uppercase tracking-wider text-ink-500">
      Automatic Git worktree sync · TUI · MCP server
    </p>

    <h1 class="mt-4 text-balance text-center text-5xl font-bold leading-[1.12] tracking-tight text-ink-900 sm:text-6xl md:text-7xl">
      {positioning.heroHeadlineLine1}
      <span class="block bg-gradient-to-r from-accent-600 via-accent-500 to-accent-400 bg-clip-text pb-[0.15em] text-transparent">
        {positioning.heroHeadlineLine2}
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-3xl text-balance text-center text-lg leading-relaxed text-ink-600 sm:text-xl">
      <strong class="text-ink-900">sync-worktrees</strong> <span set:html={inlineCodeToHtml(positioning.heroSubhead)} />
    </p>
    <p class="mx-auto mt-3 max-w-2xl text-balance text-center text-sm leading-relaxed text-ink-500">
      {positioning.heroDiskNote}
    </p>

    <div class="mx-auto mt-12 grid max-w-5xl items-stretch gap-4 lg:grid-cols-[1fr_auto_1fr]">
      <div class="min-w-0 rounded-2xl border border-ink-200 bg-white p-5 text-left shadow-sm">
        <div class="flex items-center gap-2 text-sm font-semibold text-ink-700">
          <span class="inline-flex size-7 items-center justify-center rounded-full bg-ink-50 text-xs ring-1 ring-ink-200">1</span>
          Just a config
        </div>
        <div class="mt-4 rounded-xl bg-ink-50 p-4 font-mono text-xs leading-6 text-ink-700 ring-1 ring-ink-100">
          <pre class="overflow-x-auto">{showcaseConfig}</pre>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-ink-600">
          Declare your repos and branches once. Commit the file — every teammate and every new machine rebuilds the exact same workspace.
        </p>
      </div>

      <div class="flex items-center justify-center gap-3">
        <div class="rounded-lg bg-ink-900 px-3 py-2 font-mono text-sm text-white shadow-sm">
          <span class="text-accent-400">$</span> sync-worktrees
        </div>
        <span class="text-ink-300 rotate-90 lg:rotate-0">
          <Icon name="arrow-right" size={22} />
        </span>
      </div>

      <div class="min-w-0 overflow-hidden rounded-2xl border border-ink-800 bg-ink-900 text-left shadow-lg">
        <div class="flex items-center gap-1.5 border-b border-ink-800 px-4 py-2.5">
          <span class="size-3 rounded-full bg-[#ff5f57]"></span>
          <span class="size-3 rounded-full bg-[#febc2e]"></span>
          <span class="size-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-2 font-mono text-xs text-ink-400">bootstrapping — in seconds</span>
        </div>
        <div class="space-y-1 p-4 font-mono text-xs leading-5 text-ink-200">
          <div class="sw-line" style="animation-delay:0s"><span class="text-emerald-400">✓</span> cloned frontend</div>
          <div class="sw-line" style="animation-delay:0.4s"><span class="text-emerald-400">✓</span> frontend/main</div>
          <div class="sw-line" style="animation-delay:0.8s"><span class="text-emerald-400">✓</span> frontend/feature-login</div>
          <div class="sw-line" style="animation-delay:1.2s"><span class="text-emerald-400">✓</span> cloned backend</div>
          <div class="sw-line" style="animation-delay:1.6s"><span class="text-emerald-400">✓</span> backend/main</div>
          <div class="sw-line" style="animation-delay:2s"><span class="text-emerald-400">✓</span> backend/release-2.4</div>
          <div class="sw-line mt-2 border-t border-ink-800 pt-2 text-ink-400" style="animation-delay:2.6s">worktrees/</div>
          <div class="sw-line text-ink-200" style="animation-delay:2.85s">├─&nbsp;frontend/</div>
          <div class="sw-line text-ink-400" style="animation-delay:3s">│&nbsp;&nbsp;├─&nbsp;main</div>
          <div class="sw-line text-ink-400" style="animation-delay:3.15s">│&nbsp;&nbsp;└─&nbsp;feature-login</div>
          <div class="sw-line text-ink-200" style="animation-delay:3.35s">└─&nbsp;backend/</div>
          <div class="sw-line text-ink-400" style="animation-delay:3.5s">&nbsp;&nbsp;&nbsp;├─&nbsp;main</div>
          <div class="sw-line text-ink-400" style="animation-delay:3.65s">&nbsp;&nbsp;&nbsp;└─&nbsp;release-2.4</div>
          <div class="sw-line mt-2 border-t border-ink-800 pt-2 text-accent-400" style="animation-delay:4s">↳ MCP exposes this workspace to agents</div>
          <div class="sw-line pt-1 font-semibold text-emerald-400" style="animation-delay:4.4s">workspace ready</div>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center gap-4">
      <a
        href="#quickstart"
        class="inline-flex items-center gap-2 rounded-full bg-accent-500 px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-accent-400"
      >
        Get started <Icon name="arrow-right" size={18} />
      </a>
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm">
        <span class="inline-flex items-center gap-2 font-mono text-ink-600">
          <span class="text-accent-600">$</span> {npmCmd}
          <CopyButton value={npmCmd} class="text-ink-500 hover:bg-ink-100" />
        </span>
        <span class="text-ink-300" aria-hidden="true">·</span>
        <a href="#agents" class="font-medium text-accent-700 underline-offset-4 hover:underline">
          Works with AI agents via MCP →
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelector('a[href="https://github.com/yordan-kanchelov/sync-worktrees"]')
    ?.addEventListener("click", function () {
      window.posthog?.capture("github_link_clicked", { location: "hero" });
    });

  // Refresh the build-time star count with a live value on page load, so the
  // badge stays current between static rebuilds.
  fetch("https://api.github.com/repos/yordan-kanchelov/sync-worktrees", {
    headers: { Accept: "application/vnd.github+json" },
  })
    .then(function (res) {
      return res.ok ? res.json() : null;
    })
    .then(function (data) {
      if (!data || typeof data.stargazers_count !== "number") return;
      var badge = document.getElementById("gh-stars");
      var value = badge && badge.querySelector("[data-star-value]");
      if (!badge || !value) return;
      var n = data.stargazers_count;
      value.textContent = n >= 1000 ? (n / 1000).toFixed(1) + "k" : String(n);
      badge.classList.remove("hidden");
    })
    .catch(function () {});
</script>

<style>
  .sw-line {
    opacity: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sw-line {
      animation: sw-cascade 7s ease-in-out infinite;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sw-line {
      opacity: 1;
    }
  }
  @keyframes sw-cascade {
    0%,
    4% {
      opacity: 0;
      transform: translateY(3px);
    }
    10%,
    86% {
      opacity: 1;
      transform: translateY(0);
    }
    94%,
    100% {
      opacity: 0;
      transform: translateY(0);
    }
  }
</style>
