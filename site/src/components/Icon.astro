  </svg>
)}
{name === "check" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <polyline points="20 6 9 17 4 12"/>
  </svg>
)}
{name === "arrow-right" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <line x1="5" y1="12" x2="19" y2="12"/>
    <polyline points="12 5 19 12 12 19"/>
  </svg>
)}
{name === "chevron-right" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <polyline points="9 6 15 12 9 18"/>
  </svg>
)}
{name === "sparkle" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <path d="M12 3 13.5 9 19 10.5 13.5 12 12 18 10.5 12 5 10.5 10.5 9 12 3Z"/>
    <path d="M19 17v4"/>
    <path d="M17 19h4"/>
  </svg>
)}
{name === "folder-tree" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <path d="M3 5a2 2 0 0 1 2-2h3l2 2h5a2 2 0 0 1 2 2v2"/>
    <path d="M3 5v6a2 2 0 0 0 2 2h2"/>
    <rect x="9" y="13" width="12" height="8" rx="1"/>
    <line x1="13" y1="17" x2="17" y2="17"/>
  </svg>
)}
{name === "command" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <path d="M9 6a3 3 0 1 0-3 3h12a3 3 0 1 0-3-3v12a3 3 0 1 0 3-3H6a3 3 0 1 0 3 3V6Z"/>
  </svg>
)}
{name === "clone" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <rect x="3" y="3" width="13" height="13" rx="2"/>
    <path d="M8 21h11a2 2 0 0 0 2-2V8"/>
  </svg>
)}
