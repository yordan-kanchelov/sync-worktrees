---
export interface Props {
  name:
    | "github"
    | "npm"
    | "terminal"
    | "git-branch"
    | "robot"
    | "shield"
    | "filter"
    | "monitor"
    | "copy"
    | "check"
    | "arrow-right"
    | "chevron-right"
    | "sparkle"
    | "folder-tree"
    | "command"
    | "clone";
  class?: string;
  size?: number | string;
  "aria-hidden"?: boolean;
}

const { name, class: cls = "", size = 20, "aria-hidden": ariaHidden = true } = Astro.props;
const dim = typeof size === "number" ? size : Number(size);
---
{name === "github" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="currentColor" class={cls} aria-hidden={ariaHidden}>
    <path d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.18c-3.2.7-3.87-1.37-3.87-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.3-.52-1.49.11-3.1 0 0 .97-.31 3.17 1.18a10.96 10.96 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.61.23 2.8.12 3.1.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.68.41.35.78 1.05.78 2.12v3.14c0 .31.21.66.8.55C20.21 21.4 23.5 17.1 23.5 12.02 23.5 5.66 18.36.5 12 .5Z"/>
  </svg>
)}
{name === "npm" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="currentColor" class={cls} aria-hidden={ariaHidden}>
    <path d="M2 4h20v16H12.5v-2.5H7V20H2V4Zm2 14h3V8h3v10h3V6H4v12Zm10-12v10h3V8h3v8h2V6H14Z"/>
  </svg>
)}
{name === "terminal" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <polyline points="4 17 10 11 4 5"/>
    <line x1="12" y1="19" x2="20" y2="19"/>
  </svg>
)}
{name === "git-branch" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <line x1="6" y1="3" x2="6" y2="15"/>
    <circle cx="18" cy="6" r="3"/>
    <circle cx="6" cy="18" r="3"/>
    <path d="M18 9a9 9 0 0 1-9 9"/>
  </svg>
)}
{name === "robot" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <rect x="3" y="8" width="18" height="12" rx="2"/>
    <line x1="12" y1="3" x2="12" y2="8"/>
    <circle cx="12" cy="3" r="1"/>
    <circle cx="9" cy="13" r="1"/>
    <circle cx="15" cy="13" r="1"/>
    <line x1="9" y1="17" x2="15" y2="17"/>
  </svg>
)}
{name === "shield" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <path d="M12 2 4 5v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V5l-8-3Z"/>
    <polyline points="9 12 11 14 15 10"/>
  </svg>
)}
{name === "filter" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <polygon points="3 4 21 4 14 12 14 19 10 21 10 12 3 4"/>
  </svg>
)}
{name === "monitor" && (
  <svg width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden={ariaHidden}>
    <rect x="2" y="3" width="20" height="14" rx="2"/>
    <line x1="8" y1="21" x2="16" y2="21"/>
    <line x1="12" y1="17" x2="12" y2="21"/>
  </svg>
)}
{name === "copy" && (
