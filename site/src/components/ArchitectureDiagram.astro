---
import Icon from "./Icon.astro";
---
<section class="bg-ink-50 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-ink-600">
        How it lays out
      </div>
      <h2 class="mt-4 text-balance text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        One bare repo. Many branches. One shared shape.
      </h2>
      <p class="mt-4 text-balance text-lg text-ink-600">
        Sync-worktrees stores Git objects once in a bare repository, then materializes one working tree per remote branch. You and your AI agent both see the same layout — no surprises.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-[1.3fr_1fr]">
      <div class="rounded-2xl border border-ink-200 bg-white p-6 font-mono text-sm shadow-sm">
        <div class="mb-3 flex items-center gap-2 text-xs uppercase tracking-wider text-ink-500">
          <Icon name="folder-tree" size={14} /> Filesystem layout
        </div>
<pre class="overflow-x-auto text-ink-800 leading-relaxed">
<span class="text-ink-400">.</span>
├── <span class="font-semibold text-ink-700">sync-worktrees.config.js</span>
├── <span class="text-accent-700">.bare/</span>                          <span class="text-ink-400"># shared git database</span>
│   ├── frontend/
│   └── backend/
└── <span class="text-accent-700">worktrees/</span>
    ├── <span class="text-accent-700">frontend/</span>
    │   ├── <span class="text-emerald-600">main/</span>                  <span class="text-ink-400"># one folder per remote branch</span>
    │   ├── <span class="text-emerald-600">feature-login/</span>
    │   └── <span class="text-emerald-600">release-2.4/</span>
    └── <span class="text-accent-700">backend/</span>
        ├── <span class="text-emerald-600">main/</span>
        ├── <span class="text-emerald-600">feature-login/</span>
        └── <span class="text-amber-600">.diverged/</span>                <span class="text-ink-400"># force-push survivors</span>
</pre>
      </div>

      <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-sm">
        <div class="flex items-center gap-2 text-xs uppercase tracking-wider text-ink-500">
          <Icon name="command" size={14} /> Who sees what
        </div>
        <div class="mt-4 space-y-4">
          <div class="rounded-xl bg-ink-50 p-4">
            <div class="text-sm font-semibold text-ink-900">You</div>
            <p class="mt-1 text-sm text-ink-600">
              <code class="font-mono text-xs">cd worktrees/frontend/feature-login</code> — switching branches is just changing directory. <code class="font-mono text-xs">grep -r</code> across the whole workspace.
            </p>
          </div>
          <div class="rounded-xl bg-accent-50 p-4 ring-1 ring-accent-100">
            <div class="flex items-center gap-2 text-sm font-semibold text-accent-800">
              <Icon name="robot" size={14} /> Your AI agent
            </div>
            <p class="mt-1 text-sm text-ink-700">
              Calls <code class="font-mono text-xs text-accent-800">detect_context</code> from any worktree and gets the entire layout back — every repo, every branch — in one response.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
