---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProblemSolution from "../components/ProblemSolution.astro";
import AgentIntegration from "../components/AgentIntegration.astro";
import QuickStart from "../components/QuickStart.astro";
import BootstrapRepositories from "../components/BootstrapRepositories.astro";
import WhenNotToUse from "../components/WhenNotToUse.astro";
import FAQ from "../components/FAQ.astro";
import CallToAction from "../components/CallToAction.astro";
import Footer from "../components/Footer.astro";
import { mdToPlainText } from "../lib/markdown-inline";
import { faqUrl } from "../lib/faq";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://sync-worktrees.com";
const faqs = (await getCollection("faq")).sort((a, b) => a.data.order - b.data.order);

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((entry) => ({
    "@type": "Question",
    name: entry.data.question,
    url: `${siteUrl}${faqUrl(entry.id)}`,
    acceptedAnswer: { "@type": "Answer", text: mdToPlainText(entry.body ?? "") },
  })),
};
---
<BaseLayout extraJsonLd={[faqJsonLd]}>
  <main>
    <Hero />
    <ProblemSolution />
    <BootstrapRepositories />
    <QuickStart />
    <AgentIntegration />
    <WhenNotToUse />
    <FAQ />
    <CallToAction />
  </main>
  <Footer />
</BaseLayout>
