---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page not found — sync-worktrees">
  <main class="grid min-h-screen place-items-center bg-white px-6">
    <div class="text-center">
      <p class="font-mono text-sm text-ink-500">404</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-ink-900">Page not found.</h1>
      <p class="mt-3 text-ink-600">Probably <code class="font-mono">git checkout</code> the wrong branch.</p>
      <a href="/" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-ink-900 px-4 py-2 text-sm font-medium text-white hover:bg-ink-800">
        Back to sync-worktrees
      </a>
    </div>
  </main>
</BaseLayout>
